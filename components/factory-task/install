set -euo pipefail
set -x

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

kubectl apply -f "${DIR}/crd.yaml"

echo "FactoryTask CRD installed."

INSTALL_FACTORY_TASK_RUNTIME=${INSTALL_FACTORY_TASK_RUNTIME:-false}

if [[ "${INSTALL_FACTORY_TASK_RUNTIME}" != "true" ]]; then
    exit 0
fi

FACTORY_IMAGE=${FACTORY_IMAGE:-}
FACTORY_NAMESPACE=${FACTORY_NAMESPACE:-factory-system}
GITHUB_TOKEN=${GITHUB_TOKEN:-}
GITLAB_TOKEN=${GITLAB_TOKEN:-}
WEBHOOK_SECRET=${WEBHOOK_SECRET:-}
AI_FACTORY_OPENAI_API_KEY=${AI_FACTORY_OPENAI_API_KEY:-}
OPENAI_API_KEY=${OPENAI_API_KEY:-${AI_FACTORY_OPENAI_API_KEY}}
OPENAI_BASE_URL=${OPENAI_BASE_URL:-}
OPENAI_MODEL=${OPENAI_MODEL:-}
OPENAI_TEMPERATURE=${OPENAI_TEMPERATURE:-}
OPENAI_MAX_TOKENS=${OPENAI_MAX_TOKENS:-}
OPENAI_MAX_TOOL_ROUNDS=${OPENAI_MAX_TOOL_ROUNDS:-}
CODEX_API_KEY=${CODEX_API_KEY:-}

if [[ -z "${FACTORY_IMAGE}" ]]; then
    echo "Error: FACTORY_IMAGE is required when INSTALL_FACTORY_TASK_RUNTIME=true."
    echo "Example: FACTORY_IMAGE=registry.example.com/ai-factory/factory:latest INSTALL_FACTORY_TASK_RUNTIME=true components/factory-task/install"
    exit 1
fi

kubectl create namespace "${FACTORY_NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

SECRET_ARGS=()
if [[ -n "${GITHUB_TOKEN}" ]]; then
    SECRET_ARGS+=(--from-literal="GITHUB_TOKEN=${GITHUB_TOKEN}")
fi
if [[ -n "${GITLAB_TOKEN}" ]]; then
    SECRET_ARGS+=(--from-literal="GITLAB_TOKEN=${GITLAB_TOKEN}")
fi
if [[ -n "${WEBHOOK_SECRET}" ]]; then
    SECRET_ARGS+=(--from-literal="WEBHOOK_SECRET=${WEBHOOK_SECRET}")
fi
if [[ -n "${OPENAI_API_KEY}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_API_KEY=${OPENAI_API_KEY}")
fi
if [[ -n "${OPENAI_BASE_URL}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_BASE_URL=${OPENAI_BASE_URL}")
fi
if [[ -n "${OPENAI_MODEL}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_MODEL=${OPENAI_MODEL}")
fi
if [[ -n "${OPENAI_TEMPERATURE}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_TEMPERATURE=${OPENAI_TEMPERATURE}")
fi
if [[ -n "${OPENAI_MAX_TOKENS}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_MAX_TOKENS=${OPENAI_MAX_TOKENS}")
fi
if [[ -n "${OPENAI_MAX_TOOL_ROUNDS}" ]]; then
    SECRET_ARGS+=(--from-literal="OPENAI_MAX_TOOL_ROUNDS=${OPENAI_MAX_TOOL_ROUNDS}")
fi
if [[ -n "${CODEX_API_KEY}" ]]; then
    SECRET_ARGS+=(--from-literal="CODEX_API_KEY=${CODEX_API_KEY}")
fi

if [[ ${#SECRET_ARGS[@]} -gt 0 ]]; then
    kubectl -n "${FACTORY_NAMESPACE}" create secret generic factory-task-secrets "${SECRET_ARGS[@]}" --dry-run=client -o yaml | kubectl apply -f -
fi

"${DIR}/render-runtime" | kubectl apply -f -

echo "FactoryTask runtime installed."
