set -euo pipefail

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

FACTORY_IMAGE=${FACTORY_IMAGE:-}
FACTORY_NAMESPACE=${FACTORY_NAMESPACE:-factory-system}
FACTORY_TASK_NAMESPACE=${FACTORY_TASK_NAMESPACE:-default}
IMAGE_PULL_POLICY=${IMAGE_PULL_POLICY:-IfNotPresent}
WATCH_INTERVAL=${WATCH_INTERVAL:-15s}
SANDBOX_TIMEOUT=${SANDBOX_TIMEOUT:-5m}
REQUIRE_LABEL=${REQUIRE_LABEL:-ai-factory}
SANDBOX_TEMPLATE=${SANDBOX_TEMPLATE:-go-dev}
AGENT_NAME=${AGENT_NAME:-builder}
AGENT_COMMAND=${AGENT_COMMAND:-ai-factory-agent openai-compatible}
PROMPT_REF=${PROMPT_REF:-.agents/builder/agent.md}
TASK_COMMAND=${TASK_COMMAND:-go test ./...}
CHANGE_REQUEST=${CHANGE_REQUEST:-true}
WEBHOOK_INGRESS_HOST=${WEBHOOK_INGRESS_HOST:-}
WEBHOOK_INGRESS_CLASS=${WEBHOOK_INGRESS_CLASS:-}

if [[ -z "${FACTORY_IMAGE}" ]]; then
    echo "Error: FACTORY_IMAGE is required." >&2
    echo "Example: FACTORY_IMAGE=registry.example.com/ai-factory/factory:latest components/factory-task/render-runtime" >&2
    exit 1
fi

sed_escape() {
    printf '%s' "$1" | sed -e 's/[\/&|]/\\&/g'
}

sed \
    -e "s|__NAMESPACE__|$(sed_escape "${FACTORY_NAMESPACE}")|g" \
    -e "s|__TASK_NAMESPACE__|$(sed_escape "${FACTORY_TASK_NAMESPACE}")|g" \
    -e "s|__FACTORY_IMAGE__|$(sed_escape "${FACTORY_IMAGE}")|g" \
    -e "s|__IMAGE_PULL_POLICY__|$(sed_escape "${IMAGE_PULL_POLICY}")|g" \
    -e "s|__WATCH_INTERVAL__|$(sed_escape "${WATCH_INTERVAL}")|g" \
    -e "s|__SANDBOX_TIMEOUT__|$(sed_escape "${SANDBOX_TIMEOUT}")|g" \
    -e "s|__REQUIRE_LABEL__|$(sed_escape "${REQUIRE_LABEL}")|g" \
    -e "s|__SANDBOX_TEMPLATE__|$(sed_escape "${SANDBOX_TEMPLATE}")|g" \
    -e "s|__AGENT_NAME__|$(sed_escape "${AGENT_NAME}")|g" \
    -e "s|__AGENT_COMMAND__|$(sed_escape "${AGENT_COMMAND}")|g" \
    -e "s|__PROMPT_REF__|$(sed_escape "${PROMPT_REF}")|g" \
    -e "s|__TASK_COMMAND__|$(sed_escape "${TASK_COMMAND}")|g" \
    -e "s|__CHANGE_REQUEST__|$(sed_escape "${CHANGE_REQUEST}")|g" \
    "${DIR}/runtime.yaml"

if [[ -n "${WEBHOOK_INGRESS_HOST}" ]]; then
    cat <<EOF
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: factory-task-webhook
  namespace: ${FACTORY_NAMESPACE}
  labels:
    app.kubernetes.io/name: factory-task-webhook
    app.kubernetes.io/part-of: ai-factory
spec:
EOF
    if [[ -n "${WEBHOOK_INGRESS_CLASS}" ]]; then
        echo "  ingressClassName: ${WEBHOOK_INGRESS_CLASS}"
    fi
    cat <<EOF
  rules:
  - host: ${WEBHOOK_INGRESS_HOST}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: factory-task-webhook
            port:
              name: http
EOF
fi
