set -euo pipefail

# SandboxTemplate commands may override the image entrypoint. Normalize the
# toolchain path in the actual agent launcher so every child shell inherits it.
export PATH="/usr/local/go/bin:${PATH:-}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_AGENT="${SCRIPT_DIR}/ai-factory-agent.py"

usage() {
    cat >&2 <<'EOF'
Usage:
  ai-factory-agent openai-compatible
  ai-factory-agent codex [args...]
  ai-factory-agent --help

OpenAI-compatible mode reads the FactoryTask prompt from stdin and executes a
model-generated shell script in the current repository.

Required environment:
  OPENAI_API_KEY

Optional environment:
  OPENAI_BASE_URL      default: https://api.openai.com/v1
  OPENAI_MODEL         default: gpt-4.1
  OPENAI_TEMPERATURE   default: 1
  OPENAI_MAX_TOKENS    default: 48000
  OPENAI_MAX_TOOL_ROUNDS default: 40
  OPENAI_MAX_FINAL_SCRIPT_ROUNDS default: 5
  OPENAI_MAX_REPAIR_ROUNDS default: 3
EOF
}

run_openai_compatible() {
    prompt_file="$(mktemp)"
    trap 'rm -f "${prompt_file}"' RETURN
    cat > "${prompt_file}"
    if [[ ! -f "${PYTHON_AGENT}" ]]; then
        echo "ai-factory-agent.py is required beside the runtime launcher" >&2
        return 1
    fi
    AI_FACTORY_PROMPT_FILE="${prompt_file}" python3 "${PYTHON_AGENT}" "$@"
}

case "${1:-}" in
    openai-compatible)
        shift
        run_openai_compatible "$@"
        exit $?
        ;;
    codex)
        shift
        exec codex "$@"
        ;;
    -h|--help|help)
        usage
        exit 0
        ;;
esac

if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    run_openai_compatible "$@"
    exit $?
fi

echo "No agent command selected. Set AGENT_COMMAND/spec.agent.command, or provide OPENAI_API_KEY for openai-compatible mode." >&2
exit 127
