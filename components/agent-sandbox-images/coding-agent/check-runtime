set -euo pipefail
export PYTHONDONTWRITEBYTECODE=1

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_LAUNCHER="${SCRIPT_DIR}/ai-factory-agent"
PYTHON_AGENT="${SCRIPT_DIR}/ai-factory-agent.py"
AGENT_BUDGET="${SCRIPT_DIR}/agent_budget.py"
REPAIR_LOOP="${SCRIPT_DIR}/repair_loop.py"
REPAIR_PROMPT="${SCRIPT_DIR}/repair_prompt.py"
SCRIPT_VALIDATION="${SCRIPT_DIR}/script_validation.py"

bash -n "${RUNTIME_LAUNCHER}"
grep -Fq 'ai-factory-agent.py' "${RUNTIME_LAUNCHER}"

python3 - "${PYTHON_AGENT}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

python3 - "${SCRIPT_VALIDATION}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

python3 - "${AGENT_BUDGET}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

python3 - "${REPAIR_LOOP}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

python3 - "${REPAIR_PROMPT}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

PYTHONPATH="${SCRIPT_DIR}" python3 "${SCRIPT_DIR}/script_validation_test.py"
PYTHONPATH="${SCRIPT_DIR}" python3 "${SCRIPT_DIR}/agent_budget_test.py"
PYTHONPATH="${SCRIPT_DIR}" python3 "${SCRIPT_DIR}/agent_integration_test.py"
PYTHONPATH="${SCRIPT_DIR}" python3 "${SCRIPT_DIR}/repair_prompt_test.py"
PYTHONPATH="${SCRIPT_DIR}" python3 "${SCRIPT_DIR}/repair_loop_test.py"

bash "${RUNTIME_LAUNCHER}" --help >/dev/null
echo "coding-agent runtime checks passed"
