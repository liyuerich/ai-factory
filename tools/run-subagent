#!/usr/bin/env python3
import os
import subprocess
import sys
import textwrap


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <agent-name>")
        sys.exit(1)

    agent_name = sys.argv[1]
    project_id = os.environ.get("GCP_PROJECT_ID", "my-project")
    agent_image = os.environ.get(
        "AGENT_IMAGE", f"gcr.io/{project_id}/ai-factory-agent:latest"
    )
    agent_command = os.environ.get(
        "AGENT_COMMAND", "ai-factory-agent openai-compatible"
    )

    yaml_content = textwrap.dedent(
        f"""\
        apiVersion: agents.x-k8s.io/v1alpha1
        kind: Sandbox
        metadata:
          name: {agent_name}-sandbox
          labels:
            agent: {agent_name}
        spec:
          podTemplate:
            spec:
              containers:
              - name: agent
                image: {agent_image}
                env:
                - name: AGENT_NAME
                  value: {agent_name}
                - name: AGENT_COMMAND
                  value: {agent_command}
              restartPolicy: Always
        """
    )
    process = subprocess.run(
        ["kubectl", "apply", "-f", "-"],
        input=yaml_content,
        text=True,
        check=False,
    )
    if process.returncode:
        sys.exit(process.returncode)
    print("Sandbox creation requested.")


if __name__ == "__main__":
    main()
